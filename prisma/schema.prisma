generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Channel {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  level         String
  maxFlow       Float
  length        Float
  parentId      String?
  parent        Channel? @relation("ChannelTree", fields: [parentId], references: [id], onDelete: Cascade)
  children      Channel[] @relation("ChannelTree")
  propagationDelay Int
  inspectionStatus    String @default("NORMAL")
  inspectionCycleDays Int    @default(30)
  waterUtilizationCoefficient Float @default(0.95)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())

  farmers       Farmer[]
  allocations   WaterAllocation[]
  inspections   InspectionRecord[]
  maintenanceOrders MaintenanceOrder[]
  priceBinding  ChannelPriceBinding?
  roundChannels IrrigationRoundChannel[]
  monitors      WaterLevelMonitor[]
  gate          Gate?
  alerts        WaterLevelAlert[]
  sourceReports WaterSourceReport[]
  transfersFrom ChannelTransfer[] @relation("TransferSource")
  transfersTo   ChannelTransfer[] @relation("TransferTarget")
  efficiencyRecords IrrigationEfficiencyRecord[]
  channelAssessments ChannelQuarterlyAssessment[]
}

model Farmer {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  channelId   String
  channel     Channel  @relation(fields: [channelId], references: [id])
  area        Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  quotas      Quota[]
  applications WaterApplication[]
  actualUsages ActualUsage[]
  bills       WaterBill[]
  account     FarmerAccount?
  payments    PaymentRecord[]
  waterRightsAccounts WaterRightsAccount[]
  waterRightsSellOrders WaterRightsSellOrder[]
  waterRightsBuyTrades WaterRightsTradeRecord[] @relation("BuyTrades")
  waterRightsSellTrades WaterRightsTradeRecord[] @relation("SellTrades")
  credit         FarmerCredit?
  creditHistories CreditScoreHistory[]
  efficiencyRecords IrrigationEfficiencyRecord[]
  farmerAssessments FarmerQuarterlyAssessment[]
}

model Quota {
  id        String  @id @default(uuid())
  farmerId  String
  farmer    Farmer  @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  quarter   String
  year      Int
  amount    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([farmerId, year, quarter])
}

model WaterApplication {
  id              String   @id @default(uuid())
  farmerId        String
  farmer          Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  expectedFlow    Float
  expectedHours   Float
  requestVolume   Float
  submitTime      DateTime
  targetDate      DateTime
  originalTargetDate DateTime
  status          String @default("PENDING")
  failReason      String?
  conflictChannelId String?
  conflictStartTime DateTime?
  conflictEndTime   DateTime?
  postponeCount   Int @default(0)
  roundId         String?
  round           IrrigationRound? @relation(fields: [roundId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())

  allocations WaterAllocation[]
  actualUsage ActualUsage?
  postponeHistories ApplicationPostponeHistory[]
  notifications Notification[]
  efficiencyRecord IrrigationEfficiencyRecord?
}

model WaterAllocation {
  id             String   @id @default(uuid())
  applicationId  String
  application    WaterApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  channelId      String
  channel        Channel  @relation(fields: [channelId], references: [id])
  startTime      DateTime
  endTime        DateTime
  flow           Float
  createdAt      DateTime @default(now())

  @@index([channelId, startTime, endTime])

  droughtStatus  String  @default("NORMAL")
  originalFlow   Float?
}

model ActualUsage {
  id            String   @id @default(uuid())
  applicationId String   @unique
  application   WaterApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  farmerId      String
  farmer        Farmer   @relation(fields: [farmerId], references: [id])
  actualVolume  Float
  reportTime    DateTime
  deviationRate Float
  isOveruse     Boolean
  isWaste       Boolean
  createdAt     DateTime @default(now())
}

model InspectionRecord {
  id                  String   @id @default(uuid())
  channelId           String
  channel             Channel  @relation(fields: [channelId], references: [id])
  inspectorName       String
  inspectionDate      DateTime
  description         String
  problemLevel        String
  leakageRate         Float?
  siltDepth           Float?
  liningDamageLength  Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now())
}

model MaintenanceOrder {
  id                    String    @id @default(uuid())
  channelId             String
  channel               Channel   @relation(fields: [channelId], references: [id])
  planStartDate         DateTime
  estimatedDurationDays Int
  crewCode              String
  status                String    @default("PENDING_APPROVAL")
  stopWaterStart        DateTime
  stopWaterEnd          DateTime
  approvedAt            DateTime?
  startedAt             DateTime?
  acceptedAt            DateTime?
  closedAt              DateTime?
  impactAnalysis        String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now())
}

model ApplicationPostponeHistory {
  id              String   @id @default(uuid())
  applicationId   String
  application     WaterApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  farmerId        String
  originalDate    DateTime
  targetDate      DateTime
  reason          String
  createdAt       DateTime @default(now())

  @@index([applicationId])
  @@index([farmerId])
}

model Notification {
  id              String   @id @default(uuid())
  farmerId        String
  applicationId   String
  application     WaterApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type            String
  title           String
  content         String
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([farmerId])
  @@index([applicationId])
}

model WaterPriceScheme {
  id               String              @id @default(uuid())
  name             String
  code             String              @unique
  basePrice        Float
  tier1Multiplier  Float             @default(1.0)
  tier2Threshold  Float             @default(1.3)
  tier2Multiplier  Float             @default(1.5)
  tier3Multiplier  Float             @default(2.0)
  description      String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @default(now())

  channelBindings  ChannelPriceBinding[]
  bills          WaterBill[]
}

model ChannelPriceBinding {
  id            String           @id @default(uuid())
  channelId       String           @unique
  channel         Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  schemeId        String
  scheme          WaterPriceScheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())

  @@index([schemeId])
}

model WaterBill {
  id              String   @id @default(uuid())
  farmerId        String
  farmer          Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  schemeId        String
  scheme          WaterPriceScheme @relation(fields: [schemeId], references: [id])
  billingYear     Int
  billingMonth    Int
  quotaVolume     Float
  totalVolume     Float
  tier1Volume     Float    @default(0)
  tier1Amount     Float    @default(0)
  tier2Volume     Float    @default(0)
  tier2Amount     Float    @default(0)
  tier3Volume     Float    @default(0)
  tier3Amount     Float    @default(0)
  baseAmount      Float    @default(0)
  subsidyAmount   Float    @default(0)
  subsidyVolume   Float    @default(0)
  lateFeeAmount   Float    @default(0)
  totalAmount     Float    @default(0)
  paidAmount      Float    @default(0)
  remainingAmount Float    @default(0)
  status          String   @default("UNPAID")
  generatedAt     DateTime @default(now())
  dueDate         DateTime
  lastLateFeeCalc DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())

  payments        PaymentRecord[]
  tierDetails     BillTierDetail[]

  @@unique([farmerId, billingYear, billingMonth])
  @@index([schemeId])
  @@index([status])
}

model BillTierDetail {
  id          String    @id @default(uuid())
  billId      String
  bill        WaterBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  tier        Int
  rangeStart  Float
  rangeEnd    Float?
  unitPrice   Float
  volume      Float
  amount      Float
  createdAt   DateTime  @default(now())

  @@index([billId])
}

model PaymentRecord {
  id          String   @id @default(uuid())
  billId      String
  bill        WaterBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  farmerId    String
  farmer      Farmer   @relation(fields: [farmerId], references: [id])
  amount      Float
  method      String
  paidAt      DateTime @default(now())
  remark      String?
  createdAt   DateTime @default(now())

  @@index([billId])
  @@index([farmerId])
}

model FarmerAccount {
  id               String   @id @default(uuid())
  farmerId         String   @unique
  farmer           Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  isFrozen         Boolean  @default(false)
  freezeReason     String?
  frozenAt         DateTime?
  lastOverdueMonths Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())
}

model IrrigationSeason {
  id          String   @id @default(uuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  rounds      IrrigationRound[]

  @@index([startDate, endDate])
}

model IrrigationRound {
  id             String   @id @default(uuid())
  seasonId       String
  season         IrrigationSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  name           String
  startDate      DateTime
  endDate        DateTime
  waterLimit     Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now())

  channels       IrrigationRoundChannel[]
  applications   WaterApplication[]

  @@index([seasonId])
  @@index([startDate, endDate])
}

model IrrigationRoundChannel {
  id        String   @id @default(uuid())
  roundId   String
  round     IrrigationRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([roundId, channelId])
  @@index([channelId])
}

model WaterRightsAccount {
  id                String   @id @default(uuid())
  farmerId          String
  farmer            Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  year              Int
  quarter           String
  initialQuota      Float
  boughtVolume      Float    @default(0)
  soldVolume        Float    @default(0)
  usedVolume        Float    @default(0)
  frozenVolume      Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now())

  @@unique([farmerId, year, quarter])
  @@index([farmerId])
}

model WaterRightsSellOrder {
  id                String   @id @default(uuid())
  sellerId          String
  seller            Farmer   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  year              Int
  quarter           String
  sellVolume        Float
  remainingVolume   Float
  unitPrice         Float
  status            String   @default("ACTIVE")
  createdAt         DateTime @default(now())
  expiresAt         DateTime
  updatedAt         DateTime @default(now())

  trades            WaterRightsTradeRecord[]
  @@index([sellerId])
  @@index([status])
  @@index([expiresAt])
}

model WaterRightsTradeRecord {
  id                String   @id @default(uuid())
  sellOrderId       String
  sellOrder         WaterRightsSellOrder @relation(fields: [sellOrderId], references: [id], onDelete: Cascade)
  buyerId           String
  buyer             Farmer   @relation("BuyTrades", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId          String
  seller            Farmer   @relation("SellTrades", fields: [sellerId], references: [id], onDelete: Cascade)
  year              Int
  quarter           String
  volume            Float
  unitPrice         Float
  totalAmount       Float
  createdAt         DateTime @default(now())

  @@index([buyerId])
  @@index([sellerId])
  @@index([sellOrderId])
}

model WaterLevelMonitor {
  id              String   @id @default(uuid())
  code            String   @unique
  channelId       String
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  installPosition Float
  normalLower     Float
  normalUpper     Float
  alertOverUpper  Float
  alertBelowLower Float
  status          String   @default("ONLINE")
  lastReadingAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())

  readings WaterLevelReading[]
  alerts   WaterLevelAlert[]

  @@index([channelId])
  @@index([status])
}

model WaterLevelReading {
  id        String   @id @default(uuid())
  monitorId String
  monitor   WaterLevelMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  timestamp DateTime
  value     Float
  createdAt DateTime @default(now())

  @@index([monitorId, timestamp])
  @@index([timestamp])
}

model Gate {
  id                  String   @id @default(uuid())
  code                String   @unique
  channelId           String   @unique
  channel             Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  maxOpening          Float    @default(100)
  currentOpening      Float    @default(0)
  controlMode         String   @default("AUTO")
  manualOverrideUntil DateTime?
  lastAdjustedAt      DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now())

  adjustmentLogs GateAdjustmentLog[]
}

model GateAdjustmentLog {
  id              String   @id @default(uuid())
  gateId          String
  gate            Gate     @relation(fields: [gateId], references: [id], onDelete: Cascade)
  previousOpening Float
  targetOpening   Float
  reason          String
  channelId       String
  createdAt       DateTime @default(now())

  @@index([gateId])
  @@index([channelId])
  @@index([createdAt])
}

model WaterLevelAlert {
  id         String   @id @default(uuid())
  type       String
  channelId  String
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  monitorId  String?
  monitor    WaterLevelMonitor? @relation(fields: [monitorId], references: [id], onDelete: SetNull)
  value      Float?
  threshold  Float?
  message    String
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
  resolvedAt DateTime?

  @@index([type])
  @@index([channelId])
  @@index([isResolved])
  @@index([createdAt])
}

model FarmerCredit {
  id            String   @id @default(uuid())
  farmerId      String   @unique
  farmer        Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  score         Int      @default(60)
  level         String   @default("C")
  baseScore     Int      @default(20)
  paymentScore  Int      @default(0)
  deviationScore Int     @default(0)
  overuseScore  Int      @default(0)
  tradingScore  Int      @default(5)
  hasUnpaidDebt Boolean  @default(false)
  debtPenalty   Int      @default(0)
  lastCalcAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())

  @@index([level])
  @@index([score])
}

model CreditScoreHistory {
  id            String   @id @default(uuid())
  farmerId      String
  farmer        Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  type          String
  previousScore Int
  newScore      Int
  previousLevel String
  newLevel      String
  baseScore     Int      @default(20)
  paymentScore  Int      @default(0)
  deviationScore Int     @default(0)
  overuseScore  Int      @default(0)
  tradingScore  Int      @default(0)
  hasUnpaidDebt Boolean  @default(false)
  debtPenalty   Int      @default(0)
  reason        String?
  operator      String?
  createdAt     DateTime @default(now())

  @@index([farmerId])
  @@index([createdAt])
}

model WaterSourceReport {
  id         String   @id @default(uuid())
  channelId  String
  channel    Channel  @relation(fields: [channelId], references: [id])
  flow       Float
  reportedAt DateTime
  createdAt  DateTime @default(now())

  @@index([channelId])
  @@index([reportedAt])
}

model DroughtAlertEvent {
  id                String   @id @default(uuid())
  level             String
  previousLevel     String?
  supplyDemandRatio Float
  actualFlow        Float
  demandFlow        Float
  emergencyLevel    String?
  message           String
  createdAt         DateTime @default(now())

  @@index([level])
  @@index([createdAt])
}

model ChannelTransfer {
  id                  String    @id @default(uuid())
  sourceChannelId     String
  sourceChannel       Channel   @relation("TransferSource", fields: [sourceChannelId], references: [id])
  targetChannelId     String
  targetChannel       Channel   @relation("TransferTarget", fields: [targetChannelId], references: [id])
  transferredCapacity Float
  status              String    @default("ACTIVE")
  createdAt           DateTime  @default(now())
  releasedAt          DateTime?

  @@index([sourceChannelId])
  @@index([targetChannelId])
  @@index([status])
}

model SupplyDemandSnapshot {
  id                String   @id @default(uuid())
  hour              DateTime
  actualFlow        Float
  demandFlow        Float
  supplyDemandRatio Float
  droughtStatus     String
  createdAt         DateTime @default(now())

  @@unique([hour])
  @@index([hour])
}

model IrrigationEfficiencyRecord {
  id                            String   @id @default(uuid())
  applicationId                 String   @unique
  application                   WaterApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  farmerId                      String
  farmer                        Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  channelId                     String
  channel                       Channel  @relation(fields: [channelId], references: [id])
  plannedVolume                 Float
  theoreticalLossVolume         Float
  theoreticalFieldVolume        Float
  actualUsageVolume             Float?
  efficiencyDeviationRate       Float?
  compositeUtilizationCoefficient Float
  createdAt                     DateTime @default(now())

  @@index([farmerId])
  @@index([channelId])
  @@index([createdAt])
}

model QuarterlyAssessmentReport {
  id        String   @id @default(uuid())
  year      Int
  quarter   String
  createdAt DateTime @default(now())

  channelAssessments ChannelQuarterlyAssessment[]
  farmerAssessments  FarmerQuarterlyAssessment[]

  @@unique([year, quarter])
}

model ChannelQuarterlyAssessment {
  id                     String   @id @default(uuid())
  reportId               String
  report                 QuarterlyAssessmentReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  channelId              String
  channel                Channel  @relation(fields: [channelId], references: [id])
  configuredCoefficient  Float
  actualLossRate         Float
  deviation              Float
  assessmentStatus       String
  suggestion             String?
  createdAt              DateTime @default(now())

  @@index([reportId])
  @@index([channelId])
}

model FarmerQuarterlyAssessment {
  id                   String   @id @default(uuid())
  reportId             String
  report               QuarterlyAssessmentReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  farmerId             String
  farmer               Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  averageDeviationRate Float
  assessmentStatus     String
  creditScoreDeducted  Boolean  @default(false)
  createdAt            DateTime @default(now())

  @@index([reportId])
  @@index([farmerId])
}
